# Claude API Key – Required for all AI agent operations
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Deno Environment – Optional, for Deno runtime
DENO_ENV=development

# Logging Level – Optional: debug, info, warn, error
LOG_LEVEL=info

# Server Port – Optional, defaults to 5173 (Vite default)
PORT=5173
