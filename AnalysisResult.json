{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AnalysisResult",
  "description": "Final compiled analysis result — output of APEX agent",
  "type": "object",
  "required": ["result_id", "project_id", "composite_score", "traffic_light", "verdict"],
  "properties": {
    "result_id": { "type": "string", "format": "uuid" },
    "project_id": { "type": "string", "format": "uuid" },
    "engine_version": { "type": "string", "default": "6.0.0" },
    "generated_at": { "type": "string", "format": "date-time" },
    "composite_score": { "type": "number" },
    "trust_tier_applied": { "type": "integer" },
    "traffic_light": { "type": "string", "enum": ["Green", "Amber", "Red"] },
    "verdict": { "type": "string", "enum": ["Go", "Conditional", "No-Go"] },
    "buy_signal_low_usd_m": { "type": "number" },
    "buy_signal_high_usd_m": { "type": "number" },
    "buy_signal_methodology": { "type": "string" },
    "executive_summary": { "type": "string" },
    "section_scores": { "type": "array", "items": { "type": "object" } },
    "domain_summaries": { "type": "object" },
    "ripple_chains": { "type": "array", "items": { "type": "object" } },
    "top_concerns": { "type": "array", "items": { "type": "string" } },
    "seller_questions": { "type": "array", "items": { "type": "string" } },
    "missing_documents": { "type": "array", "items": { "type": "string" } },
    "fraud_flags": { "type": "array", "items": { "type": "object" } },
    "red_team_finding": { "type": "string" },
    "red_team_verdict": { "type": "string", "enum": ["PASS", "CONDITIONAL", "FAIL"] },
    "investability_conditions": { "type": "array", "items": { "type": "string" } },
    "report_html_path": { "type": "string" },
    "report_pdf_path": { "type": "string" },
    "ceo_signoff": { "type": "string" }
  }
}
