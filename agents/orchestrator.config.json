      "description": "Document ingestion and gap mapping. Must complete before Tier 1."
    },
    "tier1": {
      "name": "QP Domain Analysis",
      "execution": "parallel",
      "type": "mixed",
      "agents": ["chen_geology", "okafor_mining", "marsh_metallurgy", "kyle_jackson", "rivera_environmental", "donovan_financial"],
      "ai_agents": ["chen_geology", "okafor_mining", "marsh_metallurgy", "rivera_environmental", "donovan_financial"],
      "human_agents": ["kyle_jackson"],
      "blocking": true,
      "description": "5 AI + 1 human domain expert running simultaneously."
    },
    "tier2": {
      "name": "Cross-Domain Intelligence",
      "execution": "parallel",
      "type": "mixed",
      "agents": ["sterling_quant", "vega_comparables", "jura_regulatory", "francis_nault"],
      "ai_agents": ["sterling_quant", "vega_comparables", "jura_regulatory"],
      "human_agents": ["francis_nault"],
      "blocking": true,
      "description": "3 AI + 1 human cross-domain running simultaneously."
    },
    "tier3": {
      "name": "Validation Layer",
      "execution": "sequential",
      "type": "ai",
      "agents": ["delta_qaqc", "phantom_fraud", "sirjuan_redteam"],
      "blocking": true,
      "description": "DELTA then PHANTOM then Sir Juan Miami (Opus 4). Sequential."
    },
    "tier4": {
      "name": "Synthesis & Delivery",
      "execution": "sequential",
      "type": "ai",
      "agents": ["apex_synthesis"],
      "blocking": true,
      "description": "APEX score computation and report generation."
    },
    "tier5": {
      "name": "Principal Sign-Off",
      "execution": "sequential",
      "type": "human",
      "agents": ["steven_w"],
      "blocking": false,
      "description": "Steven W. — Principal QP authority. Final institutional sign-off. Report release gate."
