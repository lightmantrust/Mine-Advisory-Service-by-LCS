{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "QPOutput",
  "description": "Output from a single QP domain agent",
  "type": "object",
  "required": ["agent_id", "project_id", "sections", "domain_composite_score"],
  "properties": {
    "agent_id": { "type": "string" },
    "agent_name": { "type": "string" },
    "project_id": { "type": "string", "format": "uuid" },
    "timestamp": { "type": "string", "format": "date-time" },
    "model_used": { "type": "string" },
    "sections": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "score": { "type": "integer", "minimum": 1, "maximum": 100 },
          "rationale": { "type": "string" },
          "concerns": { "type": "array", "items": { "type": "string" } },
          "hidden_assumptions": { "type": "array", "items": { "type": "string" } },
          "seller_questions": { "type": "array", "items": { "type": "string" } },
          "red_flags": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "domain_composite_score": { "type": "number" },
    "cannot_score_reason": { "type": ["string", "null"] },
    "agent_verdict": { "type": "string" }
  }
}
