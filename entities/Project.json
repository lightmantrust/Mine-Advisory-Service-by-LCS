{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Project",
  "description": "Master project entity for Mine Advisory Service by LCS v6.0",
  "type": "object",
  "required": ["project_id", "project_name", "commodity", "location", "status"],
  "properties": {
    "project_id": { "type": "string", "format": "uuid" },
    "project_name": { "type": "string" },
    "commodity": { "type": "string" },
    "commodity_category": { "type": "string", "enum": ["precious_metals", "battery_critical", "base_metals", "bulk_commodities", "industrial_minerals"] },
    "location": { "type": "string" },
    "country": { "type": "string" },
    "jurisdiction": { "type": "string" },
    "study_stage": { "type": "string", "enum": ["grassroots", "exploration", "PEA", "PFS", "feasibility", "construction", "production"] },
    "status": { "type": "string", "enum": ["pending_intake", "in_analysis", "validation", "report_ready", "complete"] },
    "submitted_by": { "type": "string" },
    "submission_date": { "type": "string", "format": "date" },
    "client_reference": { "type": "string" },
    "resource_tonnage_mt": { "type": "number" },
    "resource_grade": { "type": "number" },
    "resource_grade_unit": { "type": "string" },
    "contained_metal": { "type": "number" },
    "contained_metal_unit": { "type": "string" },
    "capex_usd_m": { "type": "number" },
    "opex_usd_per_unit": { "type": "number" },
    "npv_usd_m": { "type": "number" },
    "irr_percent": { "type": "number" },
    "discount_rate_percent": { "type": "number" },
    "metal_price_assumption": { "type": "number" },
    "metal_price_unit": { "type": "string" },
    "mine_life_years": { "type": "number" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "notes": { "type": "string" }
  }
}
