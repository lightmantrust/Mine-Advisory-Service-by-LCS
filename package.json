{
  "name": "mine-advisory-service-by-lcs",
  "version": "6.0.0",
  "description": "Mine Advisory Service by LCS v6.0 — Institutional Mining DD | 16-Agent Swarm (12 AI + 4 Human) | Claude Sonnet 4 + Opus 4 | Lightman Trust Group",
  "private": true,
  "type": "module",
  "scripts": {
    "dev":      "vite",
    "build":    "vite build",
    "preview":  "vite preview",
    "server":   "deno run --allow-net --allow-env --allow-read functions/server.ts",
    "dev:full": "concurrently \"npm run server\" \"npm run dev\"",
    "analyse":  "deno run --allow-net --allow-read --allow-write --allow-env functions/analyseProject.ts",
    "swarm":    "deno run --allow-net --allow-read --allow-write --allow-env functions/runQPSwarm.ts",
    "validate": "deno run --allow-net --allow-read --allow-write --allow-env functions/validateResults.ts",
    "seed":     "deno run --allow-net --allow-read --allow-write --allow-env functions/seedProjects.ts",
    "ingest":   "deno run --allow-net --allow-read --allow-write --allow-env functions/ingestDocument.ts",
    "report":   "python3 gen_reports.py"
  },
  "dependencies": {
    "react":     "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently":         "^8.2.2",
    "eslint":               "^9.9.0",
    "vite":                 "^5.4.1"
  },
  "engines": { "node": ">=18.0.0" },
  "author": "Steven W. — Principal QP & CEO Founder, Lightman Trust Group / LCS",
  "license": "UNLICENSED"
}
