{
  "name": "@lcs/mine-advisory-engine",
  "version": "6.0.0",
  "tasks": {
    "server":   "deno run --allow-net --allow-env --allow-read functions/server.ts",
    "analyse":  "deno run --allow-net --allow-read --allow-write --allow-env functions/analyseProject.ts",
    "swarm":    "deno run --allow-net --allow-read --allow-write --allow-env functions/runQPSwarm.ts",
    "validate": "deno run --allow-net --allow-read --allow-write --allow-env functions/validateResults.ts",
    "seed":     "deno run --allow-net --allow-read --allow-write --allow-env functions/seedProjects.ts",
    "ingest":   "deno run --allow-net --allow-read --allow-write --allow-env functions/ingestDocument.ts"
  },
  "imports": {
    "@anthropic-ai/sdk": "npm:@anthropic-ai/sdk@0.27.0"
  },
  "compilerOptions": {
    "strict": true,
    "lib": ["deno.window"]
  },
  "fmt": {
    "indentWidth": 2,
    "singleQuote": false
  }
}
